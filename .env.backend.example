SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:3000
DEBUG=false

DATABASE_URL=postgresql://postgres:postgres@db:5432/youtube_slides
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=sk-...

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# BFF pattern: Google redirects to the Next.js frontend proxy, not directly to FastAPI.
# In production: https://your-frontend-domain/api/auth/callback/google
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
