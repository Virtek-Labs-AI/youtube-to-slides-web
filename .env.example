# This file is a combined reference. Copy to .env.backend and .env.frontend as described below.
# See docs/setup.md for full instructions.

# ── .env.backend ──────────────────────────────────────────────────────────────
# App
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:3000
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/youtube_slides

# Redis
REDIS_URL=redis://redis:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback/google

# Token encryption key — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── .env.frontend ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
