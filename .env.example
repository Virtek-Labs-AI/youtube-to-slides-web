# This file is a combined reference. Copy to .env.backend and .env.frontend as described below.
# See docs/setup.md for full instructions.

# ── .env.backend ──────────────────────────────────────────────────────────────
# App
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:3000
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/youtube_slides

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI (used by both the API slide generator and the self-hosted Presenton service)
OPENAI_API_KEY=sk-...

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback/google

# Token encryption key — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# S3-compatible object storage — required on Railway (API and Celery use separate filesystems)
# Supports AWS S3, Cloudflare R2, or any S3-compatible provider.
# Leave blank to use local filesystem (docker-compose dev with shared named volume).
S3_BUCKET=
# Set for Cloudflare R2 (https://<accountid>.r2.cloudflarestorage.com) or MinIO; omit for AWS S3
S3_ENDPOINT_URL=
# Standard AWS credential env vars — read natively by boto3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Use "auto" for Cloudflare R2; use a real region name for AWS S3 (e.g. us-east-1)
AWS_DEFAULT_REGION=auto

# Presenton self-hosted presentation generator
# In docker-compose dev this is set automatically (http://presenton:5000).
# On Railway, set PRESENTON_URL to the internal URL of your Presenton service.
# Leave blank to fall back to the plain python-pptx renderer.
PRESENTON_URL=http://presenton:5000

# YouTube proxy — required on Railway to bypass IP blocks
# Generic proxy URL with credentials: http://user:pass@gate.example.com:10000
YOUTUBE_PROXY_URL=
# OR Webshare residential (takes precedence over YOUTUBE_PROXY_URL if both are set)
YOUTUBE_WEBSHARE_USERNAME=
YOUTUBE_WEBSHARE_PASSWORD=

# ── .env.frontend ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
